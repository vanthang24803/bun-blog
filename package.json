{
	"name": "api",
	"license": "Apache-2.0",
	"module": "boostrap.ts",
	"type": "module",
	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bun": "latest",
		"@types/figlet": "^1.7.0",
		"drizzle-kit": "^0.31.10"
	},
	"scripts": {
		"dev": "bun run --hot boostrap.ts",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bun run src/db/migrate.ts",
		"db:studio": "bunx drizzle-kit studio",
		"format": "bunx --bun @biomejs/biome format --write .",
		"lint": "bunx --bun @biomejs/biome lint --write .",
		"check": "bunx --bun @biomejs/biome check --write .",
		"build": "bun build ./boostrap.ts --compile --outfile server",
		"test": "bun test tests/",
		"test:watch": "bun test --watch tests/"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.105.4",
		"drizzle-orm": "^0.45.2",
		"figlet": "^1.11.0",
		"jose": "^6.2.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"zod": "^4.4.2"
	}
}
