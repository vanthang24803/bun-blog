{
	"name": "@app/api",
	"module": "src/bootstrap.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --hot src/bootstrap.ts",
		"build": "bun build ./src/bootstrap.ts --compile --outfile server",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bun run src/db/migrate.ts",
		"db:push": "bunx drizzle-kit push",
		"db:studio": "bunx drizzle-kit studio",
		"type-check": "bunx tsc --noEmit",
		"test": "bun test src/tests/",
		"test:unit": "bun test unit",
		"test:e2e": "bun test e2e",
		"test:watch": "bun test --watch src/tests/"
	},
	"dependencies": {
		"@app/shared": "workspace:*",
		"drizzle-orm": "^0.45.2",
		"figlet": "^1.11.0",
		"jose": "^6.2.3",
		"postgres": "^3.4.9",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"zod": "^4.4.2"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/figlet": "^1.7.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "^5"
	}
}